import pygame, sys, random
pygame.init()

# värvid
red = [255, 0, 0]
lBlue = [153, 204, 255]

# ekraani seaded
screenX = 640
screenY = 480
screen = pygame.display.set_mode([screenX, screenY])
pygame.display.set_caption("Animeerimine")
screen.fill(lBlue)
clock = pygame.time.Clock()

# palli laadimine
ball = pygame.image.load("img/ball.png")

# palli koht ja kiirus
posX = 0
posY = 0
speedX = 3
speedY = 4

# ruutude list
coords = []
for i in range(10):
    x = random.randint(1, screenX)
    y = random.randint(1, screenY)
    speed = random.randint(1, 5)
    coords.append([x, y, speed])

gameover = False

while not gameover:
    clock.tick(60)

    # sulgemine ristist
    for i in pygame.event.get():
       if i.type == pygame.QUIT:
           sys.exit()

    # pall
    screen.blit(ball, (posX, posY))
    posX += speedX
    posY += speedY

    # pall põrkab tagasi
    if posX > screenX - ball.get_rect().width or posX < 0:
        speedX = -speedX
    if posY > screenY - ball.get_rect().height or posY < 0:
        speedY = -speedY

    # ruudud langevad alla
    for i in range(len(coords)):
        pygame.draw.rect(screen, red, [coords[i][0], coords[i][1], 20, 20])
        coords[i][1] += coords[i][2]
        if coords[i][1] > screenY:
            coords[i][1] = random.randint(-40, -10)
            coords[i][0] = random.randint(0, screenX)

    pygame.display.flip()
    screen.fill(lBlue)

pygame.quit()